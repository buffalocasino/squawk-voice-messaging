// src/router/index.js or equivalent setup file
const registerSW = module.exports = module.exports = async () => {
    if (!('serviceWorker' in navigator)) {
        console.log('Service Worker not supported in this browser.');
        return;
    }

    try {
        const registration = await navigator.serviceWorker.register('/service-worker.js');
        console.log('Service Worker registered successfully with scope:', registration.scope);

        // Handle updates
        registration.addEventListener('updatefound', () => {
            const newWorker = registration.installing;
            if (newWorker) {
                console.log('New Service Worker found, waiting for it to activate...');
            }
        });

        registration.addEventListener('activate', (event) => {
            console.log('Service Worker activated. Running cleanup...');
            // Clean up old caches here (e.g., stored in a cacheStorage service)
            // Example: const cachePromises = Array.from(event.storage);
            // return Promise.all(cachePromises);
        });

    } catch (error) {
        console.error('Service Worker registration failed:', error);
    }
};