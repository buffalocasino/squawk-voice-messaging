{
  "$schema": "https://raw.githubusercontent.com/nickolay/tauri-config-schema/main/v2.schema.json",
  "productName": "Squawk",
  "version": "0.1.0",
  "identifier": "com.tvashtar.squawk",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5175",
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev"
  },
  "app": {
    "title": "Squawk",
    "windows": [
      {
        "title": "Squawk",
        "width": 420,
        "height": 780,
        "minWidth": 360,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "center": true,
        "transparent": false,
        "backgroundColor": "#0d0d1a",
        "titleBarStyle": "Overlay",
        "hiddenTitle": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'wasm-unsafe-eval'; connect-src 'self' ws: wss: stun:; media-src 'self' blob:; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'",
      "dangerousDisableAssetCspModification": false,
      "freezePrototype": true,
      "pattern": {
        "use": "brownfield"
      }
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "tooltip": "Squawk — Encrypted Voice Messaging"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "SocialNetworking",
    "shortDescription": "Encrypted voice messages. P2P. No server.",
    "longDescription": "Squawk is a zero-knowledge, ephemeral messaging app with end-to-end Olm encryption, DOD-grade data wiping, duress passcodes, and panic shake. Voice messages are encrypted peer-to-peer with no central server storing your data.",
    "resources": [],
    "copyright": "© 2026 Tvashtar Gaming",
    "license": "MIT",
    "publisher": "Tvashtar Gaming",
    "createUpdaterArtifacts": false
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "notification": {
      "all": true
    },
    "global-shortcut": {
      "all": true
    }
  }
}
