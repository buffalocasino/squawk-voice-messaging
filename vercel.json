{
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/pnpm"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "mask": "/(.*)",
      "to": "index.html"
    }
  ],
  "buildCommand": "pnpm run build",
  "outputDirectory": ".svelte-kit/output",
  "devCommand": "pnpm run dev --port $PORT"
}