{
  "id": "com.tvashtar.squawk",
  "name": "Squawk — Encrypted Voice",
  "short_name": "Squawk",
  "description": "Zero-knowledge, ephemeral voice messaging. End-to-end encrypted. P2P. No server stores your messages.",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "display_override": ["standalone", "minimal-ui"],
  "orientation": "portrait",
  "lang": "en",
  "dir": "ltr",

  "background_color": "#0d0d1a",
  "theme_color": "#0d0d1a",

  "launch_handler": {
    "client_mode": "focus-existing"
  },

  "prefer_related_applications": false,
  "related_applications": [],

  "categories": ["social", "communication", "utilities"],

  "icons": [
    {
      "src": "/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icon-192-maskable.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icon-512-maskable.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],

  "screenshots": [],

  "shortcuts": [
    {
      "name": "New Voice Squawk",
      "short_name": "Squawk",
      "description": "Record and send an encrypted voice message",
      "url": "/?action=squawk",
      "icons": [
        { "src": "/icon-192.png", "sizes": "192x192" }
      ]
    },
    {
      "name": "Open Contacts",
      "short_name": "Contacts",
      "description": "View your peer contacts",
      "url": "/?action=contacts",
      "icons": [
        { "src": "/icon-192.png", "sizes": "192x192" }
      ]
    }
  ],

  "edge_side_panel": {
    "preferred_width": 420
  },

  "handle_links": "preferred",
  "capture_links": "existing-client-navigate"
}
